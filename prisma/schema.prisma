// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id                Int            @id @default(autoincrement())
  email             String         @unique
  phoneNumber       String
  name              String
  password          String
  preferredLanguage LanguageOption @default(ENGLISH)
  role              Role           @default(USER)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  cultivations            Cultivation[]
  notifications           Notification[]
  diseaseDetectionResults DiseaseDetectionResult[]
  chatbotMessages         ChatbotMessage[]

  @@map("users")
}

enum LanguageOption {
  ENGLISH
  SINHALA
}

enum Role {
  USER
  ADMIN
}

model Cultivation {
  id           Int               @id @default(autoincrement())
  startDate    DateTime
  seedType     String
  sizeInAcres  Float
  paddyVariety String
  status       CultivationStatus @default(ACTIVE)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  userId Int @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cultivations")
}

enum CultivationStatus {
  ACTIVE
  COMPLETED
}

model Fertilizer {
  id         Int              @id @default(autoincrement())
  imgPath    String?
  name       String
  pricePerKg Float            @default(0.0)
  status     FertilizerStatus @default(ACTIVE)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  @@map("fertilizers")
}

enum FertilizerStatus {
  ACTIVE
  INACTIVE
}

model Notification {
  id        Int                @id @default(autoincrement())
  title     String
  content   String
  status    NotificationStatus @default(NOT_READ)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  userId Int @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationStatus {
  READ
  NOT_READ
}

model DiseaseDetectionResult {
  id                    String           @id @default(uuid())
  imagePath             String?
  disease               String
  diseaseScientificName String?
  riskLevel             DiseaseRiskLevel
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  userId Int @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("disease_detection_results")
}

enum DiseaseRiskLevel {
  LOW
  MEDIUM
  HIGH
}

model ChatbotMessage {
  id            Int       @id @default(autoincrement())
  content       String    @db.Text
  deliveredTime DateTime? @default(now())
  sender        Sender    @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  userId Int @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chatbot_messages")
}

enum Sender {
  USER
  CHATBOT
}
